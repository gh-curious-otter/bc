# bcstats — TimescaleDB for bc workspace time-series metrics
# Usage: docker build -t bc-bcstats:latest -f docker/Dockerfile.bcstats .

FROM timescale/timescaledb:2.19.1-pg17

ENV POSTGRES_USER=bc \
    POSTGRES_DB=bcstats

COPY docker/bcstats/init.sql /docker-entrypoint-initdb.d/01-init.sql

EXPOSE 5432
HEALTHCHECK --interval=5s --timeout=3s --start-period=10s --retries=3 \
    CMD pg_isready -U bc -d bcstats
