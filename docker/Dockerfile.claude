# Claude Code agent image
# Usage: docker build -t bc-agent-claude:latest -f docker/Dockerfile.claude .
# Requires: bc-agent-base:latest (docker build -f docker/Dockerfile.base .)

FROM bc-agent-base:latest AS base

USER root

# Install Claude Code native binary (includes syntax highlighting + tree-sitter)
SHELL ["/bin/bash", "-c"]
RUN curl -fsSL https://claude.ai/install.sh | bash && \
    cp /root/.local/share/claude/versions/* /usr/local/bin/claude && \
    chmod +x /usr/local/bin/claude && \
    rm -rf /root/.local/share/claude /root/.claude

# Pre-configure bc MCP server so agents can query workspace state
# bcd runs on the host — accessible via host.docker.internal from containers
USER agent
RUN claude mcp add --transport http bc http://host.docker.internal:9374/mcp/sse 2>/dev/null || true
WORKDIR /workspace
ENTRYPOINT ["bash", "-c"]
