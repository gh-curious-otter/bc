# bcsql — Postgres for bc workspace SQL storage
# Usage: docker build -t bc-bcsql:latest -f docker/Dockerfile.bcsql .

FROM postgres:17.4-alpine

ENV POSTGRES_USER=bc \
    POSTGRES_DB=bc

COPY docker/bcsql/init.sql /docker-entrypoint-initdb.d/01-init.sql

EXPOSE 5432
HEALTHCHECK --interval=5s --timeout=3s --start-period=10s --retries=3 \
    CMD pg_isready -U bc -d bc
