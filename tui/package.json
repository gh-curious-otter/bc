{
  "name": "@bc/tui",
  "version": "0.1.0",
  "description": "Terminal UI for bc agent orchestration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun run tsc",
    "dev": "bun run tsc --watch",
    "start": "bun run dist/index.js",
    "lint": "bun run eslint src",
    "typecheck": "bun run tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@bc/tui": ".",
    "ink": "^4.4.1",
    "ink-text-input": "^5.0.1",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^8.54.0",
    "@types/bun": "^1.1.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "ink-testing-library": "^3.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^7.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
