# bc workspace secrets — DO NOT COMMIT
# Copy to .env and fill in your values.

# ─── bc core ────────────────────────────────────────────────────────
# BC_HOME              Override default bc config directory (~/.bc)
# BC_STATE_DIR         Override state/data directory (default: $BC_HOME)
# BC_WORKSPACE         Path to workspace root (set automatically for agents)
# BC_BIN               Path to bc binary (default: bc in PATH)
# BC_ROOT              Workspace root directory (used by TUI)
# BC_HOST_WORKSPACE    Host-side workspace path for Docker volume mounts
# BC_DAEMON_ADDR       Address of the bcd daemon (default: localhost:9374)
# BC_BCD_ADDR          bcd server address for agent ↔ server communication

# ─── agent session (set automatically, do not override) ─────────────
# BC_AGENT_ID          Current agent name
# BC_AGENT_ROLE        Current agent role
# BC_AGENT_RUNTIME     Runtime backend (tmux or docker)
# BC_AGENT_TOOL        Agent's AI tool (claude, gemini, etc.)
# BC_AGENT_WORKTREE    Path to agent's worktree
# BC_WORKTREE_NAME     Worktree directory name
# BC_PARENT_ID         Parent agent name (for sub-agents)

# ─── AI provider keys ──────────────────────────────────────────────
# Store these via `bc secret set` rather than in .env where possible.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ─── GitHub ─────────────────────────────────────────────────────────
# Required for agent operations (git push, PR creation, MCP servers).
# GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_xxxxx

# ─── Database ───────────────────────────────────────────────────────
# DATABASE_URL          PostgreSQL DSN for persistent storage (optional)
# DATABASE_URL=postgres://bc:bc@localhost:5432/bc

# TimescaleDB stats backend (optional)
# STATS_DATABASE_URL=postgres://bc:bc@localhost:5433/bcstats

# ─── General / UI ──────────────────────────────────────────────────
# EDITOR               Preferred editor for `bc config edit` (default: vi)
# NO_COLOR=1           Disable colored output (respected by CLI and TUI)
# BC_HIGH_CONTRAST=1   Enable high-contrast TUI colors
