{
  "name": "bc-agent-orchestration",
  "displayName": "bc - AI Agent Orchestration",
  "description": "VS Code integration for bc AI agent orchestration CLI",
  "version": "0.1.0",
  "publisher": "bc-tools",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ai",
    "agents",
    "orchestration",
    "cli",
    "bc"
  ],
  "activationEvents": [
    "workspaceContains:.bc"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "bc.status",
        "title": "BC: Show Status"
      },
      {
        "command": "bc.agentList",
        "title": "BC: List Agents"
      },
      {
        "command": "bc.agentCreate",
        "title": "BC: Create Agent"
      },
      {
        "command": "bc.agentStop",
        "title": "BC: Stop Agent"
      },
      {
        "command": "bc.agentStart",
        "title": "BC: Start Agent"
      },
      {
        "command": "bc.agentAttach",
        "title": "BC: Attach to Agent"
      },
      {
        "command": "bc.agentPeek",
        "title": "BC: Peek Agent Output"
      },
      {
        "command": "bc.channelSend",
        "title": "BC: Send Channel Message"
      },
      {
        "command": "bc.channelHistory",
        "title": "BC: View Channel History"
      },
      {
        "command": "bc.refresh",
        "title": "BC: Refresh",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bc-explorer",
          "title": "BC Agents",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "bc-explorer": [
        {
          "id": "bc.agentsView",
          "name": "Agents"
        },
        {
          "id": "bc.channelsView",
          "name": "Channels"
        },
        {
          "id": "bc.processesView",
          "name": "Processes"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "bc.refresh",
          "when": "view =~ /bc\\./",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "bc.agentAttach",
          "when": "view == bc.agentsView && viewItem == agent-running",
          "group": "inline"
        },
        {
          "command": "bc.agentStop",
          "when": "view == bc.agentsView && viewItem == agent-running"
        },
        {
          "command": "bc.agentStart",
          "when": "view == bc.agentsView && viewItem == agent-stopped"
        },
        {
          "command": "bc.agentPeek",
          "when": "view == bc.agentsView"
        }
      ]
    },
    "configuration": {
      "title": "BC Agent Orchestration",
      "properties": {
        "bc.binaryPath": {
          "type": "string",
          "default": "bc",
          "description": "Path to the bc binary"
        },
        "bc.refreshInterval": {
          "type": "number",
          "default": 5000,
          "description": "Status refresh interval in milliseconds"
        },
        "bc.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show bc status in the status bar"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "npm run compile && mocha ./dist/test/**/*.test.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "mocha": "^10.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.22.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rpuneet/bc"
  },
  "license": "MIT"
}
